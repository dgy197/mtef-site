    "deployCommand": "vercel deploy --prebuilt --prod --yes",
    "validationCommand": "./validate.sh . && python3 scripts/asset-guard.py --site . --output .vercel/output/static",
    "criticalInvariant": "Every local asset referenced by any HTML page must exist both in the source tree and in .vercel/output/static before production deploy. Missing /logos caused logo disappearance on 2026-05-16."
  },
