  "preDeployChecklist": [
    "Run ./validate.sh .",
    "Refresh .vercel/output/static from source or ensure copied asset dirs are current",
    "Run python3 scripts/asset-guard.py --site . --output .vercel/output/static",
    "Deploy with vercel deploy --prebuilt --prod --yes",
    "Live-check /, /logos/mtef.png, all partner logos, hero image, /hirek, /sitemap.xml, /robots.txt"
  ],
  "lastKnownIncident": {
    "date": "2026-05-16",
    "symptom": "MTEF and partner logos disappeared on mtef.hu",
    "cause": "HTML referenced /logos/*.png but .vercel/output/static/logos was missing from prebuilt deployment output.",
    "fix": "Copied root logos directory into public/logos and .vercel/output/static/logos; deployed production; verified all logo URLs returned 200.",
    "prevention": "asset-guard.py must run before every MTEF production deploy."
  },
  "contentUpdateRunbook": {
    "humanReadable": "CONTENT-UPDATE-RUNBOOK.md",
    "machineReadable": "content-update-runbook.json",
    "goldenRule": "Never update only one page. A content change must propagate to content/news.json, article page, homepage cards, /hirek list, sitemap, schema and documents.",
    "mandatoryCommands": [
      "node scripts/generate-news.mjs",
      "./validate.sh .",
      "python3 scripts/asset-guard.py --site . --output .vercel/output/static"
    ]
  }
